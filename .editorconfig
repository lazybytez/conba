root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,json5}]
indent_size = 2

[*.{js,mjs,cjs,ts,mts,cts,jsx,tsx,css,astro}]
indent_size = 2

[{Makefile,*.mk}]
indent_style = tab

[Dockerfile]
indent_style = tab

[.gitmodules]
indent_style = tab

[*.sh]
indent_size = 2
